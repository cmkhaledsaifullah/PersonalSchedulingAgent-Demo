# ──────────────────────────────────────────────────────────────────────────────
# LLM Provider Selection
# ──────────────────────────────────────────────────────────────────────────────

# Choose the default LLM provider when --llm is not passed on the command line.
# Options: anthropic | openai | google
# Default: anthropic
LLM_PROVIDER=anthropic

# Optional: override the model for any provider using LLM_MODEL (applies to all).
# Provider-specific vars below take priority over this generic one.
# LLM_MODEL=


# ──────────────────────────────────────────────────────────────────────────────
# Anthropic (Claude)   — https://console.anthropic.com/
# ──────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the default model (claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022


# ──────────────────────────────────────────────────────────────────────────────
# OpenAI (GPT-4o)      — https://platform.openai.com/api-keys
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override the default model (gpt-4o)
# OPENAI_MODEL=gpt-4o


# ──────────────────────────────────────────────────────────────────────────────
# Google Gemini        — https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# Optional: override the default model (gemini-1.5-pro)
# GOOGLE_MODEL=gemini-1.5-pro


# ──────────────────────────────────────────────────────────────────────────────
# Google OAuth2 (Gmail + Calendar)
# ──────────────────────────────────────────────────────────────────────────────

# Place your OAuth2 client secrets JSON file in the project root and
# name it credentials.json
#
# To get it:
#   1. Go to Google Cloud Console → https://console.cloud.google.com/
#   2. Create or select a project
#   3. Enable the Gmail API and Google Calendar API
#   4. Go to APIs & Services → Credentials
#   5. Create OAuth 2.0 Client ID (Desktop app)
#   6. Download the JSON and save as credentials.json in the project root
#   7. Add your email as a test user on the OAuth consent screen
#
# token.pickle will be auto-created after your first login (do not commit it).
